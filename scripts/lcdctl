#!/bin/sh

STATE_DIR=/var/lib/lcd-ui
CMD_FILE=/tmp/lcd_cmd

mkdir -p "$STATE_DIR"

case "$1" in
  ready|start|stop|info)
    echo "$1" > "$STATE_DIR/state"
    echo "$1" > "$CMD_FILE"
    ;;

  progress)
    if [ -z "$2" ]; then
      echo "Usage: lcdctl progress <0-100>"
      exit 1
    fi

    echo "$2" > "$STATE_DIR/progress"

    if [ -x /usr/bin/fb_progress ]; then
      /usr/bin/fb_progress "$2"
    fi
    ;;

  status)
    echo "LCD UI status"
    echo "-------------"
    echo "state: $(cat "$STATE_DIR/state" 2>/dev/null)"
    echo "progress: $(cat "$STATE_DIR/progress" 2>/dev/null)"
    echo "fb0: $(test -e /dev/fb0 && echo OK || echo MISSING)"
    echo "app process: $(pidof lcd_app >/dev/null && echo running || echo stopped)"
    ;;

  repaint)
    if [ -x /usr/bin/fb_progress ]; then
      /usr/bin/fb_progress "$(cat "$STATE_DIR/progress" 2>/dev/null || echo 75)"
    fi
    ;;

  *)
    echo "Usage:"
    echo "  lcdctl ready"
    echo "  lcdctl start"
    echo "  lcdctl stop"
    echo "  lcdctl info"
    echo "  lcdctl progress <0-100>"
    echo "  lcdctl status"
    echo "  lcdctl repaint"
    exit 1
    ;;
esac
